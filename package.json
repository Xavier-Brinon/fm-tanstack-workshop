{
  "name": "fm-tanstack-workshop",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "pg": "podman container run -e POSTGRES_USER=docker -e POSTGRES_PASSWORD=docker -p 5433:5432 -v ~/Documents/pg-data:/var/lib/postgresql postgres:18.2-alpine3.23",
    "pg-raw": "podman container run -e POSTGRES_USER=docker -e POSTGRES_PASSWORD=docker -p 5433:5432 postgres:18.2-alpine3.23",
    "pg-clear": "rm -rf ~/Documents/pg-data",
    "db-pull": "aubx drizzle-kit pull",
    "tsc": "tsc",
    "update-tanstack": "aube add @tanstack/react-devtools@latest @tanstack/react-router@latest @tanstack/react-router-devtools@latest @tanstack/react-router-ssr-query@latest @tanstack/react-start@latest @tanstack/router-plugin@latest"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-devtools": "^0.10.8",
